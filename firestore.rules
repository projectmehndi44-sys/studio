rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is authenticated via Firebase Auth.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an Admin or Owner based on their verified phone number.
     * Specific numbers provided: +916000861935 (Admin), +919613993713 (Owner).
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.phone_number == '+916000861935' || 
        request.auth.token.phone_number == '+919613993713'
      );
    }

    /**
     * @description Rules for Product management.
     */
    match /products/{productId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for Shop Settings.
     */
    match /settings/config {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for Purchase transactions.
     */
    match /purchases/{purchaseId} {
      allow read, create: if isSignedIn();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for manual cash flow entries.
     */
    match /cashTransactions/{transactionId} {
      allow read, create: if isSignedIn();
      allow delete: if isAdmin();
    }

    /**
     * @description Default deny for all other paths.
     */
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
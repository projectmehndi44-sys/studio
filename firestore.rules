rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow an unauthenticated user to read only the team members configuration
    // This is required for the login page to verify credentials.
    match /config/teamMembers {
      allow get: if true;
      allow list, create, update, delete: if false;
    }

    // Allow any authenticated user (logged-in admin) to read and write to all other documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

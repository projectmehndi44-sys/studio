rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles and permissions
    function getTeamMembers() {
      return get(/databases/$(database)/documents/config/teamMembers).data.members;
    }

    function getUserData(userId) {
      // Find user by their auth UID. The 'id' field in team-data.ts must match the user's auth UID.
      // For the default admin, this won't match, so we rely on isSuperAdmin.
      // This is primarily for future-proofing if team members are linked to Firebase Auth users.
      // For now, role is checked by username.
      let matchingUsers = getTeamMembers().filter(member => member.username == request.auth.token.email);
      return matchingUsers.size() > 0 ? matchingUsers[0] : null;
    }

    function isSuperAdmin() {
      let userData = getUserData(request.auth.uid);
      return userData != null && userData.role == 'Super Admin';
    }

    function hasPermission(module, level) {
      if (isSuperAdmin()) {
        return true;
      }
      let userData = getUserData(request.auth.uid);
      if (userData == null || !module in userData.permissions) {
        return false;
      }
      let permission = userData.permissions[module];
      if (level == 'edit') {
        return permission == 'edit';
      }
      if (level == 'view') {
        return permission == 'view' || permission == 'edit';
      }
      return false;
    }

    // --- Public access for Login ---
    // Allow the login page to read the list of team members to verify credentials.
    match /config/teamMembers {
      allow get, list: if true;
    }

    // Allow anyone to read master services and locations for the main site to function.
    match /config/masterServices {
      allow get, list: if true;
    }
     match /config/availableLocations {
      allow get, list: if true;
    }

    // --- Authenticated Access Rules ---
    match /artists/{artistId} {
      // Any logged-in user (admin/team) can view artists.
      // Only users with 'artists:edit' permission can create/update/delete.
      allow read: if hasPermission('artists', 'view');
      allow write: if hasPermission('artists', 'edit');
    }

    match /bookings/{bookingId} {
      allow read: if hasPermission('bookings', 'view');
      allow write: if hasPermission('bookings', 'edit');
    }

    match /customers/{customerId} {
      allow read: if hasPermission('customers', 'view');
      allow write: if hasPermission('customers', 'edit');
    }

    match /pendingArtists/{artistId} {
        allow read, write: if hasPermission('artists', 'edit');
    }
    
    match /payoutHistory/{payoutId} {
        allow read, write: if hasPermission('payouts', 'edit');
    }

    // --- Settings & Config Rules (Admin/Edit Only) ---
    match /config/{docId} {
        // This covers promotions, financialSettings, companyProfile, packages etc.
        allow read, write: if hasPermission('settings', 'edit');
    }
    
     match /notifications/{notificationId} {
      allow read, write: if hasPermission('notifications', 'edit');
    }

    // Fallback rule: deny all other access
    match /{path=**} {
      allow read, write: if false;
    }
  }
}

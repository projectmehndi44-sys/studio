rules_version = '2';

// This is the final, correct set of rules.
// It allows the login page to work and then grants full access to any logged-in admin or team member.
// The user interface code handles the different permission levels (Super Admin vs. Team Member).
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny all access. Specific rules below will grant access.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow anyone (specifically the login page) to read the list of team members
    // to verify credentials before a user is authenticated.
    match /config/teamMembers {
      allow get, list: if true;
    }

    // Allow any authenticated user (any admin or team member who has successfully logged in)
    // to read and write to all other collections and documents.
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}

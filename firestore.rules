rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles from the 'teamMembers' config document
    function isSuperAdmin() {
      // Check if the requesting user's UID exists in the team members list and their role is 'Super Admin'
      return request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members &&
             get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role == 'Super Admin';
    }

    function isTeamMember() {
      // Check if the requesting user's UID is present in the team members list
      return request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members;
    }

    // Rule for the 'config' collection
    match /config/{docId} {
      // Allow anyone to read config files (needed for login to read team members)
      allow read;
      // Only allow Super Admins to write to config files
      allow write: if isSuperAdmin();
    }
    
    // Rule for all other collections in the database
    match /{collection}/{docId} {
        // Allow read, write, and delete access only to authenticated team members or admins
        allow read, write, delete: if isTeamMember();
    }
  }
}

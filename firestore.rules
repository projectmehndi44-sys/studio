rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to the team members config for login verification.
    // This is necessary for the current client-side login implementation.
    match /config/teamMembers {
      allow read: if true;
      allow write: if false; // Should only be updated from a trusted environment
    }

    // Allow read access to other configuration files like master services, locations, etc.
    match /config/{docId} {
        allow read: if true;
        allow write: if request.auth != null; // Allow logged-in admins to write
    }
    
    // Allow anyone to submit a pending artist registration
    match /pendingArtists/{artistId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null; // Only admins can manage
    }

    // Allow authenticated users to manage their own data and bookings
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /bookings/{bookingId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null; // Allow customers and assigned artists to read
        allow update: if request.auth != null; // Allow admins to update
    }

    // Default to locked down for other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

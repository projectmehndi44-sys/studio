
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is authenticated and is a part of the authorized staff list.
     */
    function isAuthorizedStaff() {
      let staffNumbers = [
        '+916000861935', 
        '+919613993713', 
        '+919181540323', 
        '+918822081421'
      ];
      return request.auth != null && request.auth.token.phone_number in staffNumbers;
    }

    /**
     * @description Checks if the user is specifically the Admin or Owner.
     */
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.phone_number == '+916000861935' || 
        request.auth.token.phone_number == '+919613993713'
      );
    }

    match /products/{productId} {
      // All staff can read products to bill them
      allow read: if isAuthorizedStaff();
      // Only Admin/Owner can manage the Stock Master
      allow create, update, delete: if isAdmin();
    }

    match /settings/config {
      // Only Admin/Owner can see or change shop profile
      allow read, write: if isAdmin();
    }

    match /purchases/{purchaseId} {
      // All staff can create bills
      allow create: if isAuthorizedStaff();
      // Only Admin/Owner can read the sales ledger
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /cashTransactions/{transactionId} {
      // All staff can log cash in/out
      allow create: if isAuthorizedStaff();
      // Only Admin/Owner can see cash logs in the ledger
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}

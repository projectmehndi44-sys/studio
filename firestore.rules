
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to the teamMembers config for login verification.
    // This is secure because it only contains non-sensitive data like usernames and roles.
    match /config/teamMembers {
      allow get: if true;
    }
    
    // Deny all other public reads or writes by default.
    // Specific authenticated access can be added below this rule.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

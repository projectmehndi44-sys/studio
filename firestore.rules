rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is authenticated and is a part of the authorized staff list.
     * Authorized Numbers: Admin (+916000861935), Owner (+919613993713), Geeta Churi (+919181540323), Muskan Das (+918822081421).
     */
    function isAuthorizedStaff() {
      let staffNumbers = [
        '+916000861935', 
        '+919613993713', 
        '+919181540323', 
        '+918822081421'
      ];
      return request.auth != null && request.auth.token.phone_number in staffNumbers;
    }

    /**
     * @description Standard admin check for destructive operations.
     */
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.phone_number == '+916000861935' || 
        request.auth.token.phone_number == '+919613993713'
      );
    }

    match /products/{productId} {
      allow read, create, update: if isAuthorizedStaff();
      allow delete: if isAdmin();
    }

    match /settings/config {
      allow read, create, update: if isAuthorizedStaff();
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read, create: if isAuthorizedStaff();
      allow delete: if isAdmin();
    }

    match /cashTransactions/{transactionId} {
      allow read, create: if isAuthorizedStaff();
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
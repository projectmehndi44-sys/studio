
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    //  HELPER FUNCTIONS - These make the rules easier to read and manage
    // =====================================================================

    // Safely checks if the user is a Super Admin.
    function isSuperAdmin() {
      return request.auth != null 
        && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data
        && get(/databases/$(database)/documents/config/teamMembers).data[request.auth.uid].role == 'Super Admin';
    }

    // Safely checks if the user is a Team Member.
    function isTeamMember() {
      return request.auth != null 
        && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data
        && get(/databases/$(database)/documents/config/teamMembers).data[request.auth.uid].role == 'team-member';
    }

    // The main permission checking function. It now uses correct syntax without 'let' or 'if'.
    function hasPermission(module, level) {
      // Use a ternary operator to correctly handle view/edit logic
      return (level == 'view')
        ? (get(/databases/$(database)/documents/config/teamMembers).data[request.auth.uid].permissions[module] in ['view', 'edit'])
        : (get(/databases/$(database)/documents/config/teamMembers).data[request.auth.uid].permissions[module] == level);
    }
    
    // --- Public & Customer Rules (Evaluated for non-admins) ---
    match /artists/{artistId} {
      allow get, list: if true;
      allow update: if request.auth != null && request.auth.uid == artistId;
    }
    match /masterServices/{docId} {
      allow get, list: if true;
    }
    match /config/availableLocations {
      allow get: if true;
    }
    match /customers/{customerId} {
      allow create: if true;
      allow get, update: if request.auth != null && request.auth.uid == customerId;
    }
    match /pendingArtists/{docId} {
      allow create: if true;
    }
    match /bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }


    // --- Admin & Team Member Rules (Evaluated for admins) ---
    // These rules are evaluated alongside public rules. Access is granted if EITHER condition is met.
    
    match /bookings/{docId} {
      allow read: if isTeamMember() && hasPermission('bookings', 'view');
      allow write: if isTeamMember() && hasPermission('bookings', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /artists/{docId} {
      allow read: if isTeamMember() && hasPermission('artists', 'view');
      allow write: if isTeamMember() && hasPermission('artists', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /customers/{docId} {
      allow read: if isTeamMember() && hasPermission('customers', 'view');
      allow write: if isTeamMember() && hasPermission('customers', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /masterServices/{docId} {
      allow read: if isTeamMember() && hasPermission('packages', 'view');
      allow write: if isTeamMember() && hasPermission('packages', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /config/{docId} {
      allow read: if isTeamMember() && hasPermission('settings', 'view');
      allow write: if isTeamMember() && hasPermission('settings', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /pendingArtists/{docId} {
      allow read, write: if isSuperAdmin() || (isTeamMember() && hasPermission('artists', 'edit'));
    }
  }
}

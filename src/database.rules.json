
{
  "rules": {
    "service cloud.firestore": {
      "match": "/databases/{database}/documents",

      "function": "isSuperAdmin()",
      "function": "isTeamMember()",
      "function": "hasPermission(module, level)",
      "function": "isOwner(resourceId)",

      "// All other documents are locked down by default": {
        "match": "/{document=**}",
        "allow": {
          "read, write": "if false;"
        }
      },

      "artists": {
        "match": "/{artistId}",
        "allow": {
          "get, list": "if true;",
          "update": "if isOwner(artistId) || hasPermission('artists', 'edit') || isSuperAdmin();"
        }
      },

      "masterServices": {
        "match": "/{docId}",
        "allow": {
          "get, list": "if true;",
          "write": "if hasPermission('packages', 'edit') || isSuperAdmin();"
        }
      },

      "config": {
        "match": "/availableLocations",
        "allow": {
          "get": "if true;",
          "write": "if hasPermission('settings', 'edit') || isSuperAdmin();"
        }
      },
      "config": {
        "match": "/teamMembers",
        "allow": {
          "get": "if request.auth != null;",
          "write": "if isSuperAdmin();"
        }
      },
      "config": {
        "match": "/{docId}",
        "allow": {
          "read": "if hasPermission('settings', 'view') || isSuperAdmin();",
          "write": "if hasPermission('settings', 'edit') || isSuperAdmin();"
        }
      },

      "customers": {
        "match": "/{customerId}",
        "allow": {
          "create": "if true;",
          "get, update": "if isOwner(customerId) || hasPermission('customers', 'view') || isSuperAdmin();"
        }
      },

      "pendingArtists": {
        "match": "/{docId}",
        "allow": {
          "create": "if true;",
          "read, write": "if hasPermission('artists', 'edit') || isSuperAdmin();"
        }
      },

      "bookings": {
        "match": "/{bookingId}",
        "allow": {
          "read, write": "if request.auth != null;"
        }
      },

      "notifications": {
        "match": "/{notificationId}",
        "allow": {
          "read, write": "if request.auth != null;"
        }
      },

      "functions": {
        "isSuperAdmin": "return request.auth != null && get(/databases/$(database)/documents/config/teamMembers).data.members.get(request.auth.uid, {}).role == 'Super Admin';",
        "isTeamMember": "return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members;",
        "hasPermission": "let userPermissions = get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].permissions; return (level == 'view') ? (userPermissions[module] in ['view', 'edit']) : (userPermissions[module] == level);",
        "isOwner": "return request.auth != null && request.auth.uid == resourceId;"
      }
    }
  }
}

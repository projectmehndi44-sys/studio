
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Safely checks if a user's UID exists in the team members map before checking their role.
      // This prevents permission errors for non-admin users.
      return request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data);
    }

    // Admins get full access to everything. This rule is evaluated first.
    match /{path=**} {
      allow read, write: if isAdmin();
    }
    
    // --- Rules for NON-ADMINS ---

    // Anyone can see artists and service details.
    match /artists/{artistId} {
      allow get, list: if true;
    }
    match /masterServices/{docId} {
      allow get, list: if true;
    }
    match /config/availableLocations {
      allow get: if true;
    }

    // Any authenticated user can manage their own data.
    match /artists/{artistId} {
      allow update: if request.auth.uid == artistId;
    }
    match /customers/{customerId} {
      allow get, update: if request.auth.uid == customerId;
    }
    
    // Anyone can create an account or application.
    match /customers/{customerId} {
      allow create: if true;
    }
    match /pendingArtists/{docId} {
      allow create: if true;
    }

    // Any authenticated user can manage bookings and notifications.
    match /bookings/{bookingId} {
        allow read, write: if request.auth != null;
    }
    match /notifications/{notificationId} {
        allow read, write: if request.auth != null;
    }
  }
}

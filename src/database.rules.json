
{
  "rules": {
    "service cloud.firestore": {
      "match /databases/{database}/documents": {
        "function isAdmin()": {
          "return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data;"
        },
        "match /{path=**}": {
          "allow read, write": "if isAdmin();"
        },
        "match /artists/{artistId}": {
          "allow get, list": "if true;",
          "allow update": "if request.auth != null && request.auth.uid == artistId;"
        },
        "match /masterServices/{docId}": {
          "allow get, list": "if true;"
        },
        "match /config/availableLocations": {
          "allow get": "if true;"
        },
        "match /customers/{customerId}": {
          "allow create": "if true;",
          "allow get, update": "if request.auth != null && request.auth.uid == customerId;"
        },
        "match /pendingArtists/{docId}": {
          "allow create": "if true;"
        },
        "match /bookings/{bookingId}": {
          "allow read, write": "if request.auth != null;"
        },
        "match /notifications/{notificationId}": {
          "allow read, write": "if request.auth != null;"
        }
      }
    }
  }
}

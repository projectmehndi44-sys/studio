
{
  "rules": {
    "service cloud.firestore": {
      "match /databases/{database}/documents": {
        "function isAdmin()": {
          "return request.auth != null && get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role in ['Super Admin', 'team-member'];"
        },
        "// Admin Rules": {
          "match /{document=**}": {
            "allow read, write": "if isAdmin();"
          }
        },
        "// Public and User-Specific Rules": {
          "match /artists/{artistId}": {
            "allow get, list": "if true;",
            "allow update": "if request.auth.uid == artistId;"
          },
          "match /masterServices/{docId}": {
            "allow get, list": "if true;"
          },
          "match /config/{configDoc}": {
            "allow get": "if true;"
          },
          "match /customers/{customerId}": {
            "allow create": "if true;",
            "allow get, list, update": "if request.auth.uid == customerId;"
          },
          "match /pendingArtists/{docId}": {
            "allow create": "if true;"
          },
          "match /bookings/{bookingId}": {
            "allow read, write": "if request.auth != null;"
          },
          "match /notifications/{notificationId}": {
            "allow read, write": "if request.auth != null;"
          }
        }
      }
    }
  }
}

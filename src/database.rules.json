
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    //  HELPER FUNCTIONS - These make the rules easier to read and manage
    // =====================================================================

    function isSuperAdmin() {
      return request.auth != null 
        && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members
        && get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role == 'Super Admin';
    }

    function isTeamMember() {
      return request.auth != null 
        && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members;
    }

    function hasPermission(module, level) {
      let userPermissions = get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].permissions;
      // Use a ternary operator to correctly handle view/edit logic
      return (level == 'view')
        ? (userPermissions[module] in ['view', 'edit'])
        : (userPermissions[module] == level);
    }


    // =====================================================================
    //  SECURITY RULES
    // =====================================================================
    
    // --- Public & Customer Rules (Evaluated for non-admins) ---
    
    // Allow ANYONE (public) to read artist and service data. This is crucial for the homepage.
    match /artists/{artistId} {
      allow get, list: if true;
      allow update: if request.auth != null && request.auth.uid == artistId; // An artist can only update their own profile
    }
    match /masterServices/{docId} {
      allow get, list: if true;
    }
    match /config/availableLocations {
      allow get: if true;
    }

    // This is the critical fix: Allow any authenticated user to read the team members list
    // This is required for the application to check if a user is an admin or not upon login.
    match /config/teamMembers {
      allow get: if request.auth != null;
      allow write: if isSuperAdmin(); // Only super admin can change team members
    }

    // Allow anyone to create an account or application
    match /customers/{customerId} {
      allow create: if true;
      allow get, update: if request.auth != null && request.auth.uid == customerId; // A customer can only manage their own data
    }
    match /pendingArtists/{docId} {
      allow create: if true;
    }

    // A logged-in user can manage their bookings and notifications
    match /bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }


    // --- Admin & Team Member Rules (Evaluated in addition to public rules) ---
    // These grant EXTRA permissions to admins, without overriding public access.
    
    match /bookings/{docId} {
      allow read: if isTeamMember() && hasPermission('bookings', 'view');
      allow write: if isTeamMember() && hasPermission('bookings', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /artists/{docId} {
      allow read: if isTeamMember() && hasPermission('artists', 'view');
      allow write: if isTeamMember() && hasPermission('artists', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /customers/{docId} {
      allow read: if isTeamMember() && hasPermission('customers', 'view');
      allow write: if isTeamMember() && hasPermission('customers', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /masterServices/{docId} {
      allow read: if isTeamMember() && hasPermission('packages', 'view');
      allow write: if isTeamMember() && hasPermission('packages', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /config/{docId} {
        // This rule is a fallback. More specific rules like teamMembers above take precedence.
      allow read: if isTeamMember() && hasPermission('settings', 'view');
      allow write: if isTeamMember() && hasPermission('settings', 'edit');
      allow read, write: if isSuperAdmin();
    }
    match /pendingArtists/{docId} {
      allow read, write: if isSuperAdmin() || (isTeamMember() && hasPermission('artists', 'edit'));
    }
  }
}

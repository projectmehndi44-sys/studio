{
  "rules": {
    "service": "cloud.firestore",
    "match": "/databases/{database}/documents" {

      // --- HELPER FUNCTIONS ---
      function isSuperAdmin() {
        return request.auth != null && get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role == 'Super Admin';
      }
      function isTeamMember() {
        return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members;
      }
      function hasPermission(module, level) {
        let userPermissions = get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].permissions;
        return (level == 'view')
          ? (userPermissions[module] in ['view', 'edit'])
          : (userPermissions[module] == level);
      }
      function isOwner(resourceId) {
        return request.auth != null && request.auth.uid == resourceId;
      }

      // --- PUBLIC & GENERIC LOGGED-IN RULES ---
      match /masterServices/{docId} {
        allow read: true;
      }
      match /config/availableLocations {
        allow read: true;
      }
      match /config/teamMembers {
          allow read: true;
          allow write: if isSuperAdmin();
      }
      match /config/promotions {
          allow read: true; // All users need to check promo codes
          allow write: if isTeamMember() && hasPermission('settings', 'edit');
      }
       match /config/companyProfile {
          allow read: true;
          allow write: if isTeamMember() && hasPermission('settings', 'edit');
      }

      // --- ROLE-BASED RULES ---

      // ARTIST Rules
      match /artists/{artistId} {
        allow read: true; // Publicly readable profiles
        allow update: if isOwner(artistId) || (isTeamMember() && hasPermission('artists', 'edit'));
        allow create, delete: if isTeamMember() && hasPermission('artists', 'edit');
      }
      match /pendingArtists/{docId} {
        allow create: true; // Anyone can submit an application
        allow read, delete: if isTeamMember() && hasPermission('artists', 'edit');
      }

      // CUSTOMER Rules
      match /customers/{customerId} {
        allow create: true;
        allow read, update: if isOwner(customerId) || (isTeamMember() && hasPermission('customers', 'view'));
        allow delete: if isTeamMember() && hasPermission('customers', 'edit');
      }

      // BOOKING & NOTIFICATION Rules
      match /bookings/{bookingId} {
        allow read, write: if request.auth != null; // Logged in users can manage their own bookings
      }
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null; // Logged in users can manage their own notifications
      }

      // --- ADMIN-ONLY WRITE/MANAGE RULES ---
      match /masterServices/{docId} {
         allow write: if isTeamMember() && hasPermission('packages', 'edit');
      }
      match /config/availableLocations {
        allow write: if isTeamMember() && hasPermission('settings', 'edit');
      }
       match /config/financialSettings {
          allow read: if isTeamMember() && hasPermission('settings', 'view');
          allow write: if isTeamMember() && hasPermission('settings', 'edit');
      }
      match /payoutHistory/{docId} {
         allow read, write: if isTeamMember() && hasPermission('payouts', 'edit');
      }
      
      // Catch-all for any other config docs
      match /config/{docId} {
           allow read: if isTeamMember() && hasPermission('settings', 'view');
           allow write: if isTeamMember() && hasPermission('settings', 'edit');
      }

      // CATCH-ALL: Explicitly deny all other reads/writes for security.
      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}

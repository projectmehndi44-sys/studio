
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is a Super Admin or a team member
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/config/teamMembers).data[request.auth.uid].role in ['Super Admin', 'team-member'];
    }

    // Rules for all collections
    match /{path=**} {
      // Admins have god-mode access to everything.
      // This rule is checked first. If a user is an admin, they are granted access
      // and no further rules for this path are evaluated.
      allow read, write: if isAdmin();
    }

    // --- Public Access Rules ---
    // These rules apply to users who are NOT admins.
    
    // Anyone can view artists, service packages, and available locations.
    match /artists/{artistId} {
      allow get, list: if true;
    }
    match /masterServices/{docId} {
      allow get, list: if true;
    }
    match /config/masterServices {
      allow get: if true;
    }
    match /config/availableLocations {
      allow get: if true;
    }

    // --- Authenticated User Rules ---
    // These rules apply to users who are logged in but are NOT admins.

    // Allow artists to update their own profiles.
    match /artists/{artistId} {
      allow update: if request.auth != null && request.auth.uid == artistId;
    }
    
    // Anyone can create a new customer profile or a pending artist application.
    match /customers/{customerId} {
      allow create: if true;
    }
     match /pendingArtists/{docId} {
        allow create: if true;
    }

    // A customer can read or update their own profile.
    match /customers/{customerId} {
      allow get, update: if request.auth != null && request.auth.uid == customerId;
    }
    
    // Any authenticated user can create/read/write bookings and notifications.
    // This will be refined later if needed to be more specific.
    match /bookings/{bookingId} {
        allow read, write: if request.auth != null;
    }
    match /notifications/{notificationId} {
        allow read, write: if request.auth != null;
    }
  }
}

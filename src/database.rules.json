{
  "rules": {
    "service cloud.firestore": {
      "match": "/databases/{database}/documents": {

        "function isSuperAdmin()": "return request.auth != null && get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role == 'Super Admin';",
        "function isTeamMember()": "return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data.members;",
        "function hasPermission(module, level)": "let userPermissions = get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].permissions; return (level == 'view') ? (userPermissions[module] in ['view', 'edit']) : (userPermissions[module] == level);",
        "function isOwner(resourceId)": "return request.auth != null && request.auth.uid == resourceId;",

        // PUBLIC/LOGGED-IN READS
        "match": "/masterServices/{docId}": {
          "allow read": true;
        },
        "match": "/config/availableLocations": {
          "allow read": true;
        },
        // This is the key rule to fix the login loop. ANY authenticated user can check the list.
        "match": "/config/teamMembers": {
            "allow read": "if request.auth != null;",
            "allow write": "if isSuperAdmin();"
        },
        
        // ARTIST RULES
        "match": "/artists/{artistId}": {
          "allow read": true;
          "allow update": "if isOwner(artistId) || (isTeamMember() && hasPermission('artists', 'edit')) || isSuperAdmin();"
        },
        "match": "/pendingArtists/{docId}": {
          "allow create": true;
          "allow read, delete": "if (isTeamMember() && hasPermission('artists', 'edit')) || isSuperAdmin();"
        },
        
        // CUSTOMER RULES
        "match": "/customers/{customerId}": {
          "allow create": true;
          "allow read, update": "if isOwner(customerId) || (isTeamMember() && hasPermission('customers', 'view')) || isSuperAdmin();"
        },
        
        // BOOKING & NOTIFICATION RULES (Logged-in users)
        "match": "/bookings/{bookingId}": {
          "allow read, write": "if request.auth != null;"
        },
        "match": "/notifications/{notificationId}": {
          "allow read, write": "if request.auth != null;"
        },
        
        // ADMIN-ONLY WRITE/MANAGE RULES
        "match": "/masterServices/{docId}": {
           "allow write": "if (isTeamMember() && hasPermission('packages', 'edit')) || isSuperAdmin();"
        },
        "match": "/config/availableLocations": {
          "allow write": "if (isTeamMember() && hasPermission('settings', 'edit')) || isSuperAdmin();"
        },
        "match": "/config/{docId}": {
            "allow read": "if (isTeamMember() && hasPermission('settings', 'view')) || isSuperAdmin();",
            "allow write": "if (isTeamMember() && hasPermission('settings', 'edit')) || isSuperAdmin();"
        },
        "match": "/payoutHistory/{docId}": {
           "allow read, write": "if (isTeamMember() && hasPermission('payouts', 'edit')) || isSuperAdmin();"
        },

        // CATCH-ALL: Deny all other reads/writes by default for security
        "match": "/{document=**}": {
          "allow read, write": false;
        }
      }
    }
  }
}


{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "cpu": 1,
      "memory": "512MiB",
      "concurrency": 80
    },
    "rewrites": [
      {
        "source": "**",
        "function": "nextn"
      }
    ]
  }
}

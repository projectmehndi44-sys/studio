
{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-east1",
      "cpu": 1,
      "memory": "512MiB",
      "concurrency": 80
    },
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "studio",
          "region": "us-east1"
        }
      }
    ]
  }
}

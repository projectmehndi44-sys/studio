
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an individual item available for sale in the Super 9+ POS system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "isPopular": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "isActive"]
    },
    "ShopSettings": {
      "title": "ShopSettings",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Purchase": {
      "title": "Purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "staffId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "paymentMode": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CashTransaction": {
      "title": "CashTransaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/settings/config", "definition": { "entityName": "ShopSettings" } },
      { "path": "/purchases/{purchaseId}", "definition": { "entityName": "Purchase" } },
      { "path": "/cashTransactions/{transactionId}", "definition": { "entityName": "CashTransaction" } }
    ]
  }
}

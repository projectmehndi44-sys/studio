
{
  "rules": {
    "databases": {
      "{database}": {
        "documents": {
          
          // PUBLIC READ-ONLY: Allow ANYONE to read master services, locations, and the team list.
          // This is essential for the UI and the login page to function before a user is authenticated.
          // Write access is blocked to prevent public modification.
          "match /config/{docId}": {
             "allow read": "if true;",
             "allow write": "if request.auth != null;"
          },

          // AUTHENTICATED USERS: Allow any user who is successfully logged in 
          // to perform actions on the rest of the database.
          "match /{document=**}": {
            "allow read, write": "if request.auth != null;"
          }
        }
      }
    }
  }
}

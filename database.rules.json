
{
  "rules": {
    "service cloud.firestore": {
      "match": "/databases/{database}/documents",
      "function": {
        "isAdmin": "return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/config/teamMembers).data;"
      },
      "rules": {
        "artists": {
          "match": "/{artistId}",
          "rules": {
            "allow": {
              "get, list": "if true;",
              "update": "if request.auth != null && request.auth.uid == artistId;"
            }
          }
        },
        "masterServices": {
          "match": "/{docId}",
          "rules": {
            "allow": {
              "get, list": "if true;"
            }
          }
        },
        "config": {
          "match": "/masterServices",
          "rules": {
            "allow": {
              "get": "if true;"
            }
          }
        },
        "config": {
          "match": "/availableLocations",
          "rules": {
            "allow": {
              "get": "if true;"
            }
          }
        },
        "customers": {
          "match": "/{customerId}",
          "rules": {
            "allow": {
              "create": "if true;",
              "get, update": "if request.auth != null && request.auth.uid == customerId;"
            }
          }
        },
        "pendingArtists": {
          "match": "/{docId}",
          "rules": {
            "allow": {
              "create": "if true;"
            }
          }
        },
        "bookings": {
          "match": "/{bookingId}",
          "rules": {
            "allow": {
              "read, write": "if request.auth != null;"
            }
          }
        },
        "notifications": {
          "match": "/{notificationId}",
          "rules": {
            "allow": {
              "read, write": "if request.auth != null;"
            }
          }
        },
        "match": "/{path=**}",
        "rules": {
          "allow": {
            "read, write": "if isAdmin();"
          }
        }
      }
    }
  }
}

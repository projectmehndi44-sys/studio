
{
  "rules": {
    "service cloud.firestore": {
      "match /databases/{database}/documents": {
        // Allow public read for artists list on the homepage
        "match /artists/{artistId}": {
          "allow get, list": "if true;",
          "allow write": "if request.auth != null;"
        },

        // Allow public read for customer list to check for existing users
        "match /customers/{customerId}": {
          "allow get, list": "if true;",
          "allow write": "if request.auth != null && request.auth.uid == customerId;"
        },
        
        // Allow public read for configuration (like service packages)
        "match /config/{docId=**}": {
           "allow get, list": "if true;",
           "allow write": "if request.auth != null;"
        },

        // Allow any authenticated user to create bookings, etc.
        // More specific rules can be added later if needed.
        "match /{document=**}": {
          "allow read, write": "if request.auth != null;"
        }
      }
    }
  }
}


{
  "rules": {
    "databases": {
      "{database}": {
        "documents": {
          "config": {
            "teamMembers": {
              ".read": "true",
              ".write": "false"
            }
          },
          "{document=**}": {
            ".read": "request.auth != null",
            ".write": "request.auth != null"
          }
        }
      }
    }
  }
}

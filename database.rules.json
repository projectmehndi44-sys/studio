{
  "rules": {
    "databases": {
      "{database}": {
        "documents": {
          "match /config/{docId}": {
            "allow read": "if true;",
            "allow write": "if request.auth != null;"
          },
          "match /{document=**}": {
            "allow read, write": "if request.auth != null;"
          }
        }
      }
    }
  }
}

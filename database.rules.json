
{
  "rules": {
    "service cloud.firestore": {
      "match /databases/{database}/documents": {
        "function isAdmin()": {
          "return get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role == 'Super Admin' || get(/databases/$(database)/documents/config/teamMembers).data.members[request.auth.uid].role == 'team-member';"
        },
        "match /artists/{artistId}": {
          "allow get, list": "if true;",
          "allow write": "if isAdmin() || request.auth.uid == artistId;"
        },
        "match /masterServices/{docId}": {
          "allow get, list": "if true;"
        },
        "match /config/masterServices": {
          "allow get": "if true;"
        },
        "match /config/availableLocations": {
          "allow get": "if true;"
        },
        "match /customers/{customerId}": {
          "allow create": "if true;",
          "allow get, list, update": "if request.auth.uid == customerId || isAdmin();"
        },
        "match /pendingArtists/{docId}": {
          "allow create": "if true;",
          "allow read, delete": "if isAdmin();"
        },
        "match /bookings/{bookingId}": {
          "allow read, write": "if request.auth != null || isAdmin();"
        },
        "match /notifications/{notificationId}": {
          "allow read, write": "if request.auth != null || isAdmin();"
        },
        "match /{document=**}": {
          "allow read, write": "if isAdmin();"
        }
      }
    }
  }
}
